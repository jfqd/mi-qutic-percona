[client]
port = 3306
socket = /var/run/mysqld/mysqld.sock
default-character-set = utf8mb4
# ssl
# ssl_ca = /var/mysql/certs/mariadb-ca.pem
# ssl_verify_server_cert

[mysqld]
user = mysql
port = 3306
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid
bind-address = 0.0.0.0
skip-external-locking
skip_host_cache
skip_name_resolve
sql-mode="STRICT_TRANS_TABLES,STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,TRADITIONAL,NO_ENGINE_SUBSTITUTION"

# matomo
local-infile

init-connect = 'SET collation_connection = utf8mb4_unicode_ci; SET NAMES utf8mb4;'
character-set-server = 'utf8mb4'
collation-server = 'utf8mb4_unicode_ci'

# MyISAM settings
key_buffer_size = 32M
sort_buffer_size = 8M
read_buffer_size = 2M
read_rnd_buffer_size = 16M
bulk_insert_buffer_size = 64M
myisam_sort_buffer_size = 128M
myisam_max_sort_file_size = 10G
#myisam_repair_threads = 1
myisam_recover_options

# InnoDB settings
default-storage-engine = innodb
innodb_data_home_dir = /var/lib/mysql
innodb_log_group_home_dir = /var/lib/mysql
innodb_data_file_path = ibdata1:100M:autoextend
innodb_strict_mode = 1
innodb_buffer_pool_size = 16384M
innodb_log_file_size = 400M
innodb_log_buffer_size = 8M
innodb_flush_log_at_trx_commit = 1
innodb_file_per_table = 1
innodb_doublewrite = 0
innodb_io_capacity = 1500
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_max_dirty_pages_pct = 90
innodb_lock_wait_timeout = 120

# Slow query log settings
# The default logs all full table scans,tmp tables,filesorts on disk queries
#use_global_long_query_time = 1
long_query_time = 0.5
#slow_query_log_file = /var/log/mysql/slowquery.log
#slow_query_log = 1
#log_slow_filter = "full_scan,tmp_table_on_disk,filesort_on_disk"
#log_slow_verbosity = "full"

# Other general MySQL settings
table_open_cache = 768
thread_cache_size = 500
back_log = 128
tmpdir = /var/tmp
max_connections = 1000
max_connect_errors = 10
max_allowed_packet = 128M
wait_timeout = 28800
binlog_cache_size = 1M
net_buffer_length = 16384
thread_stack = 256K
tmp_table_size = 128M
max_heap_table_size = 128M
join_buffer_size = 8M
transaction_isolation = REPEATABLE-READ

# Replication settings (master to slave, master to master)
# This is not enabled by default.  There are more steps
# to this besides uncommenting the lines below.
#
server-id = ${SERVER_ID}

binlog-ignore-db = information_schema
binlog-ignore-db = performance_schema
binlog_format = row
log-bin = mysql-bin
log-bin-index = mysql-bin.index
log-error = /var/log/mysql/error.log

relay_log = mysql-relay-bin
relay_log_index = mysql-relay-bin.index
replicate-same-server-id = 0
sync_binlog = 1
expire_logs_days = 10
binlog_expire_logs_seconds = 864000
max_binlog_size = 100M
#auto-increment-increment = 1
#auto-increment-offset = 2

open_files_limit = 10240

ssl
ssl_ca=/var/mysql/certs/mysql-ca.pem
ssl_cert=/var/mysql/certs/mysql.crt
ssl_key=/var/mysql/certs/mysql.key
tls_version = TLSv1.2,TLSv1.3
require_secure_transport=on

[mysqldump]
quick
max_allowed_packet = 16M

[mysql]
no-auto-rehash
default-character-set=utf8mb4
# Remove the next comment character if you are not familiar with SQL
#safe-updates

# matomo
local-infile

[myisamchk]
key_buffer_size = 512M
sort_buffer_size = 512M
read_buffer = 8M
write_buffer = 8M

[mysqlhotcopy]
interactive-timeout
